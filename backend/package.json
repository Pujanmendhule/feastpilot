{
  "name": "feastpilot-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "ts-node src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "test:integration": "ts-node src/dev/runIntegrationTests.ts",
    "test:model": "ts-node src/dev/runModelServiceTests.ts",
    "test:persistence": "ts-node src/dev/runPersistenceVerification.ts",
    "test:recommendation": "ts-node src/dev/runRecommendationTests.ts",
    "test:refinement": "ts-node src/dev/runRefinementTests.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
